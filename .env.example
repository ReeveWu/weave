# GEMINI_API_KEY - Required
# Get your API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here

# GEMINI_MODEL - Optional (default: gemini-2.5-flash)
# Examples: gemini-2.5-flash, gemini-2.5-pro
GEMINI_MODEL=gemini-2.5-flash

# CORS_ORIGINS - Optional for the API server.
# Use a comma-separated list of frontend origins in deployed environments.
# Example: CORS_ORIGINS=https://your-frontend.example.com
CORS_ORIGINS=
